# === إعدادات الخادم ===
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# === إعدادات الأمان (مطلوب تغييرها!) ===
# أنشئ مفتاح سري قوي: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRY=7d

# === إعدادات CORS ===
# ضع رابط موقعك الفعلي (يمكن وضع عدة روابط مفصولة بفاصلة)
CORS_ORIGIN=https://yourdomain.com

# === إعدادات قاعدة البيانات ===
DB_PATH=database/chess_game.db
DATABASE_DIR=database
